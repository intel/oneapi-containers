FROM rockylinux:9

ARG DEEP_LEARNING_ESSENTIALS_VERSION="2026.0.0-614.x86_64"

# Install dependencies for Intel® oneAPI Libraries
RUN dnf update -y && \
    dnf install -y --allowerasing \
        cmake procps make gcc gcc-c++ kernel-devel pkgconfig which bzip2 openssh-server openssh-clients wget net-tools git diffutils && \
    dnf clean all && \
    rm -rf /var/cache/dnf

# repository to install Intel® oneAPI Libraries
RUN echo $'\
[oneAPI]\n\
name=Intel(R) oneAPI repository\n\
baseurl=https://yum.repos.intel.com/oneapi\n\
enabled=1\n\
gpgcheck=1\n\
repo_gpgcheck=1\n\
gpgkey=https://yum.repos.intel.com/intel-gpg-keys/GPG-PUB-KEY-INTEL-SW-PRODUCTS.PUB' \
> /etc/yum.repos.d/oneAPI.repo

# repository to install Intel® GPU drivers
RUN dnf install -y 'dnf-command(config-manager)' && \
    dnf config-manager --add-repo \
    https://repositories.intel.com/gpu/rhel/9.7/lts/2523/unified/intel-gpu-9.7.repo && \
    dnf clean all && \
    rm -rf /var/cache/dnf

RUN dnf update -y && dnf install -y \
        intel-deep-learning-essentials-${DEEP_LEARNING_ESSENTIALS_VERSION} intel-opencl intel-level-zero-gpu level-zero level-zero-devel && \
    dnf clean all && \
    rm -rf /var/cache/yum/*

ENV LANG="C.UTF-8"

ENV CCL_CONFIGURATION='cpu_gpu_dpcpp'
ENV CCL_CONFIGURATION_PATH=''
ENV CCL_ROOT='/opt/intel/oneapi/ccl/2022.0'
ENV CLASSPATH='/opt/intel/oneapi/mpi/2021.18/share/java/mpi.jar'
ENV CMAKE_PREFIX_PATH='/opt/intel/oneapi/tbb/2023.0/env/..:/opt/intel/oneapi/pti/0.17/lib/cmake/pti:/opt/intel/oneapi/mkl/2026.0/lib/cmake:/opt/intel/oneapi/dpl/2022.12/lib/cmake/oneDPL:/opt/intel/oneapi/compiler/2026.0:/opt/intel/oneapi/ccl/2022.0/lib/cmake/oneCCL'
ENV CMPLR_ROOT='/opt/intel/oneapi/compiler/2026.0'
ENV CPATH='/opt/intel/oneapi/umf/1.1/include:/opt/intel/oneapi/dev-utilities/2026.0/include:/opt/intel/oneapi/ccl/2022.0/include'
ENV CPLUS_INCLUDE_PATH='/opt/intel/oneapi/umf/1.1/include:/opt/intel/oneapi/tbb/2023.0/env/../include:/opt/intel/oneapi/pti/0.17/include:/opt/intel/oneapi/mpi/2021.18/include:/opt/intel/oneapi/mkl/2026.0/include:/opt/intel/oneapi/dpl/2022.12/include'
ENV C_INCLUDE_PATH='/opt/intel/oneapi/umf/1.1/include:/opt/intel/oneapi/tbb/2023.0/env/../include:/opt/intel/oneapi/pti/0.17/include:/opt/intel/oneapi/mpi/2021.18/include:/opt/intel/oneapi/mkl/2026.0/include'
ENV DIAGUTIL_PATH='/opt/intel/oneapi/compiler/2026.0/etc/compiler/sys_check/sys_check.sh'
ENV DPLROOT='/opt/intel/oneapi/dpl/2022.12'
ENV DPL_ROOT='/opt/intel/oneapi/dpl/2022.12'
ENV FI_PROVIDER_PATH='/opt/intel/oneapi/mpi/2021.18/opt/mpi/libfabric/lib/prov:/usr/lib64/libfabric'
ENV GDB_INFO='/opt/intel/oneapi/debugger/2026.0/share/info/'
ENV INFOPATH='/opt/intel/oneapi/debugger/2026.0/share/info'
ENV INTEL_PYTHONHOME='/opt/intel/oneapi/debugger/2026.0/opt/debugger'
ENV I_MPI_ROOT='/opt/intel/oneapi/mpi/2021.18'
ENV LD_LIBRARY_PATH='/opt/intel/oneapi/tcm/1.5/lib:/opt/intel/oneapi/umf/1.1/lib:/opt/intel/oneapi/tcm/1.5/env/../lib:/opt/intel/oneapi/tbb/2023.0/env/../lib/intel64/gcc4.8:/opt/intel/oneapi/pti/0.17/lib:/opt/intel/oneapi/mpi/2021.18/opt/mpi/libfabric/lib:/opt/intel/oneapi/mpi/2021.18/lib:/opt/intel/oneapi/mkl/2026.0/lib:/opt/intel/oneapi/debugger/2026.0/opt/debugger/lib:/opt/intel/oneapi/compiler/2026.0/opt/compiler/lib:/opt/intel/oneapi/compiler/2026.0/lib:/opt/intel/oneapi/ccl/2022.0/lib/'
ENV LIBRARY_PATH='/opt/intel/oneapi/tcm/1.5/lib:/opt/intel/oneapi/umf/1.1/lib:/opt/intel/oneapi/tbb/2023.0/env/../lib/intel64/gcc4.8:/opt/intel/oneapi/pti/0.17/lib:/opt/intel/oneapi/mpi/2021.18/lib:/opt/intel/oneapi/mkl/2026.0/lib:/opt/intel/oneapi/compiler/2026.0/lib:/opt/intel/oneapi/ccl/2022.0/lib/'
ENV MANPATH='/opt/intel/oneapi/mpi/2021.18/share/man:/opt/intel/oneapi/debugger/2026.0/share/man:/opt/intel/oneapi/compiler/2026.0/share/man:'
ENV MKLROOT='/opt/intel/oneapi/mkl/2026.0'
ENV NLSPATH='/opt/intel/oneapi/compiler/2026.0/lib/compiler/locale/%l_%t/%N'
ENV OCL_ICD_FILENAMES='/opt/intel/oneapi/compiler/2026.0/lib/libintelocl.so'
ENV ONEAPI_ROOT='/opt/intel/oneapi'
ENV PATH='/opt/intel/oneapi/mpi/2021.18/bin:/opt/intel/oneapi/mkl/2026.0/bin:/opt/intel/oneapi/dev-utilities/2026.0/bin:/opt/intel/oneapi/debugger/2026.0/opt/debugger/bin:/opt/intel/oneapi/compiler/2026.0/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin'
ENV PKG_CONFIG_PATH='/opt/intel/oneapi/tbb/2023.0/env/../lib/pkgconfig:/opt/intel/oneapi/mpi/2021.18/lib/pkgconfig:/opt/intel/oneapi/mkl/2026.0/lib/pkgconfig:/opt/intel/oneapi/dpl/2022.12/lib/pkgconfig:/opt/intel/oneapi/compiler/2026.0/lib/pkgconfig:/opt/intel/oneapi/ccl/2022.0/lib/pkgconfig/'
ENV Pti_DIR='/opt/intel/oneapi/pti/0.17/lib/cmake/pti'
ENV SETVARS_COMPLETED='1'
ENV TBBROOT='/opt/intel/oneapi/tbb/2023.0/env/..'
ENV TCMROOT='/opt/intel/oneapi/tcm/1.5/env/..'
ENV TCM_ROOT='/opt/intel/oneapi/tcm/1.5'
ENV UMF_ROOT='/opt/intel/oneapi/umf/1.1'
